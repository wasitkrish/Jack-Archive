class Main{
    function void main(){
        var List x;
        let x=List.new(1,null);
        let x=List.new(2,x);
        let x=List.new(3,x);
        let x=List.new(4,x);
        let x=List.new(5,x);
        let x=List.new(6,x);
        do x.print();
        do x.dispose();
        return;
    }
}