class Main{
    function void main(){
        var List v;
        let v = List.new(4,null);
        let v = List.new(5,v);
        let v = List.new(10,v);
        let v = List.new(20,v);
        let v = List.new(2,v);
        let v = List.new(45,v);
        do v.print();
        do v.dispose();
        return;
    }
}