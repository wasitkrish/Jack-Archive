class Add{
    function int arraddition(int num){
    var Array arr;
    var int i,count,k,sum;
    let arr=Array.new(num);
    let i=0;
    let count=1;
    while(i<num){
        let arr[i]=count*10;
        let count=count+1;
        let i = i+1;
    }
    let k=0;
    let sum=0;
    while(k<num){
        let sum = sum + arr[k];
        let k = k+1;
    }
    do arr.dispose();
    return(sum);
    }
}